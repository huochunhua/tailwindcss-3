{
  "name": "Tailwind v3",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "browser-sync start --no-scroll --port 3000 --server --startPath '/src/' & npx tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "serves": "browser-sync start --port 3000 --server --no-scroll --startPath '/src/' --no-ghost-mode",
    "serves-files": "browser-sync start --port 3000 --server --directory --files --no-scroll --startPath '/src/index.html' --no-ghost-mode",
    "watch": "npx tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "build:css": "tailwindcss -i ./src/input.css -o ./src/output.css"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.19"
  }
}
